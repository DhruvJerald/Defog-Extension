{
  "manifest_version": 3,
  "name": "Defog - YouTube Focus Mode",
  "version": "3.0",
  "description": "Blocks YouTube distractions, adds focus timer, stats, and customization.",
  "permissions": ["storage", "notifications"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
