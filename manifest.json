{
  "manifest_version": 3,
  "name": "Defog - YouTube Focus Mode",
  "version": "1.1",
  "description": "Blocks YouTube Shorts and reduces distractions.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Defog"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}